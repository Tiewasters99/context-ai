{
  "manifest_version": 3,
  "name": "Contextspaces",
  "version": "0.1.0",
  "description": "Attach Vault files from Contextspaces directly into Gmail. More surfaces (snip-from-web, save-attachments-to-matter) coming next.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Contextspaces",
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://www.contextspaces.ai/*",
    "https://mail.google.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content/gmail.js"],
      "css": ["content/gmail.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["picker/picker.html", "picker/picker.js", "picker/picker.css", "icons/*"],
      "matches": ["https://mail.google.com/*"]
    }
  ]
}
