{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/mcp.mjs": {
      "maxDuration": 30
    },
    "api/ingest.mjs": {
      "maxDuration": 60
    },
    "api/legal-source.mjs": {
      "maxDuration": 60
    },
    "api/llm.mjs": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
