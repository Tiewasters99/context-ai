{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/mcp.mjs": {
      "maxDuration": 30
    },
    "api/ingest.mjs": {
      "maxDuration": 60
    },
    "api/legal-source.mjs": {
      "maxDuration": 60
    },
    "api/llm.mjs": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    { "source": "/.well-known/oauth-authorization-server", "destination": "/api/oauth-metadata?wk=as" },
    { "source": "/.well-known/oauth-protected-resource",   "destination": "/api/oauth-metadata?wk=pr" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
